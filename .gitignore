# LibreOffice lock files
.~lock.*#

# Python-generated files
__pycache__/
test.py
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
*.txt
.env
.data/*
# Версионируем ТОЛЬКО дефолтные скиллы и пресеты агентов (без секретов/сессий).
# Пользовательские скиллы (.data/skills/user/) в git НЕ попадают.
# re-include требует, чтобы каждый родитель пути был заново включён.
!.data/skills/
.data/skills/*
!.data/skills/default/
!.data/agents/
.ruff_cache/
.pytest_cache/
.prev_git/
logs/
dist/
*.zip
scripts/
.claude/
